{
  "name": "eoy",
  "type": "module",
  "private": true,
  "scripts": {
    "clear-dist": "rimraf ./dist",
    "build": "pnpm clear-dist && pnpm run \"/^build:.*/\"",
    "build:current": "slidev build",
    "build:2025": "slidev build --base /2025/ --out ./dist/2025",
    "build:2024": "slidev build ./slides/2024.md --base /2024/ --out ../dist/2024",
    "build:2023": "slidev build ./slides/2023.md --base /2023/ --out ../dist/2023",
    "dev": "slidev",
    "export": "slidev export"
  },
  "devDependencies": {
    "@iconify-json/logos": "1.2.10",
    "@iconify-json/mdi": "1.2.3",
    "@slidev/cli": "52.12.0",
    "@slidev/theme-apple-basic": "0.25.1",
    "playwright-chromium": "1.58.2",
    "rimraf": "6.1.3"
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4"
